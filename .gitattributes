# ============================
# Universal Git Line Ending Rules for Neovim Config
# ============================

# --- Enforce LF for all code files ---
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf
*.lua       text eol=lf
*.vim       text eol=lf
*.vimrc     text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# --- Config files ---
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf

# --- Markdown / Docs ---
*.md        text eol=lf

# --- Windows batch files keep CRLF ---
*.cmd       text eol=crlf
*.bat       text eol=crlf

# --- Binary files (Git will not modify) ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.ttf       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary

# --- Prevent plugin directories from being normalized ---
pack/**     -text

